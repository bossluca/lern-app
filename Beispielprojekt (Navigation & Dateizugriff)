def main():
    while True:
        print("\n📘 Prüfungssimulator")
        print("1 - Neue Frage hinzufügen")
        print("2 - Quiz starten")
        print("3 - Beenden")

        auswahl = input("Wähle eine Option (1-3): ")

        if auswahl == "1":
            frage_hinzufuegen(DATEIPFAD)
        elif auswahl == "2":
            fragen = fragen_laden(DATEIPFAD)
            if fragen:
                quiz_starten(fragen)
        elif auswahl == "3":
            print("👋 Auf Wiedersehen!")
            break
        else:
            print("❌ Ungültige Eingabe.")

if __name__ == "__main__":
    main()

